<Window x:Class="WeatherApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:local="clr-namespace:WeatherApp.ViewModels"
        mc:Ignorable="d"
        Title="погода"
        Height="850"
        Width="1200"
        Background="#1E1E1E">

    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <SolidColorBrush x:Key="CardBackground" Color="#2D2D30"/>
        <SolidColorBrush x:Key="TextPrimary" Color="White"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#AAAAAA"/>
        <SolidColorBrush x:Key="AccentColor" Color="#FF4A9EFF"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- боковая панель избранное -->
        <Border Grid.Column="0" 
                Background="{StaticResource CardBackground}" 
                CornerRadius="15" 
                Margin="0,0,20,0"
                Padding="15">
            <StackPanel>
                <TextBlock Text="⭐ избранное"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"
                           Margin="0,0,0,15"/>

                <ListBox ItemsSource="{Binding SavedCities}"
                         SelectedItem="{Binding PickedCity}"
                         Background="Transparent"
                         BorderThickness="0"
                         Height="350">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#3A3A3D"
                                    Margin="0,5"
                                    Padding="10"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Cursor="Hand">
                                        <TextBlock Text="⭐" Foreground="#FFBB0A1E" FontSize="14" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Name}" Foreground="White" FontSize="14"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="поиск города"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"
                           Margin="0,20,0,10"/>

                <TextBox Text="{Binding CityInput, UpdateSourceTrigger=PropertyChanged}"
                         Height="40"
                         FontSize="14"
                         Foreground="Black"
                         Background="White"
                         Padding="10"
                         Margin="0,0,0,10"/>

                <Button Content="найти"
                        Command="{Binding FetchWeatherCmd}"
                        Background="{StaticResource AccentColor}"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="Bold"
                        Cursor="Hand"
                        BorderThickness="0"
                        Height="35"
                        Margin="0,0,0,10"/>

                <Button Content="обновить"
                        Command="{Binding ManualRefreshCmd}"
                        Background="#3A3A3D"
                        Foreground="White"
                        FontSize="14"
                        Cursor="Hand"
                        BorderThickness="0"
                        Height="35"
                        Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- основной контент -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="20,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- текущая погода -->
                <Border Grid.Row="0"
                        Background="{StaticResource CardBackground}"
                        CornerRadius="15"
                        Padding="20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding CurrentCityName}" 
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>

                            <Button Grid.Column="1" 
                                    Command="{Binding ToggleFavoriteCmd}"
                                    Width="40" Height="40" FontSize="20"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Content" Value="☆"/>
                                        <Setter Property="Foreground" Value="#888"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCityFavorite}" Value="True">
                                                <Setter Property="Content" Value="⭐"/>
                                                <Setter Property="Foreground" Value="#FFBB0A1E"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <TextBlock Text="{Binding WeatherStatus}"
                                   FontSize="16"
                                   Foreground="#88BBFF"
                                   Margin="0,5,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Margin="5,5,5,5" Padding="15" Background="#3A3A3D" CornerRadius="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding CurrentTemp, StringFormat={}{0:F1}°C}" FontSize="22" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="температура" FontSize="12" Foreground="#888" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Margin="5,5,5,5" Padding="15" Background="#3A3A3D" CornerRadius="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding HumidityLevel, StringFormat={}{0}%}" FontSize="22" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="влажность" FontSize="12" Foreground="#888" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Margin="5,5,5,5" Padding="15" Background="#3A3A3D" CornerRadius="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding WindKph, StringFormat={}{0:F1} м/с}" FontSize="22" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="ветер" FontSize="12" Foreground="#888" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="3" Margin="5,5,5,5" Padding="15" Background="#3A3A3D" CornerRadius="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding PressureValue, StringFormat={}{0} hPa}" FontSize="22" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="давление" FontSize="12" Foreground="#888" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock Text="{Binding DataFreshness, StringFormat='последнее обновление: HH:mm:ss'}" 
                                   FontSize="11" 
                                   Foreground="#666" 
                                   HorizontalAlignment="Right" 
                                   Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>

                <!-- график температуры -->
                <Border Grid.Row="1"
                        Background="{StaticResource CardBackground}"
                        CornerRadius="15"
                        Padding="20"
                        Margin="0,0,0,20"
                        Height="400">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="температура по часам"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,20"/>

                        <lvc:CartesianChart Grid.Row="1"
                                            Series="{Binding TemperatureSeries}"
                                            XAxes="{Binding TimeAxis}"
                                            Background="#1A1A1A"/>
                    </Grid>
                </Border>

                <!-- прогноз на 5 дней -->
                <Border Grid.Row="2"
                        Background="{StaticResource CardBackground}"
                        CornerRadius="15"
                        Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="прогноз на 5 дней"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,15"/>

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding WeekForecasts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#3A3A3D" 
                                            CornerRadius="10" 
                                            Width="200" 
                                            Margin="10" 
                                            Padding="15">
                                        <StackPanel>
                                            <TextBlock FontWeight="Bold" Foreground="White" FontSize="14" HorizontalAlignment="Center">
                                                <Run Text="{Binding ForecastDate, StringFormat=dd.MM}"/>
                                            </TextBlock>

                                            <TextBlock Text="{Binding Condition}" 
                                                       Foreground="#88BBFF" 
                                                       FontSize="12" 
                                                       TextWrapping="Wrap"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,10,0,10"/>

                                            <Grid Margin="0,5,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" Background="#2A2A2D" CornerRadius="8" Padding="10" Margin="0,0,5,0">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="мин" FontSize="10" Foreground="#888"/>
                                                        <TextBlock Foreground="#88BBFF" FontSize="18" HorizontalAlignment="Center">
                                                            <Run Text="{Binding LowestTemp, StringFormat={}{0:F1}}"/>
                                                            <Run Text="°C"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="1" Background="#2A2A2D" CornerRadius="8" Padding="10" Margin="5,0,0,0">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="макс" FontSize="10" Foreground="#888"/>
                                                        <TextBlock Foreground="#FF8888" FontSize="18" HorizontalAlignment="Center">
                                                            <Run Text="{Binding HighestTemp, StringFormat={}{0:F1}}"/>
                                                            <Run Text="°C"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
    
