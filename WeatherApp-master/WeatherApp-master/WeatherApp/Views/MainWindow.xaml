<Window x:Class="WeatherApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:local="clr-namespace:WeatherApp.ViewModels"
        mc:Ignorable="d"
        Title="Погода"
        Height="850"
        Width="1200"
        Background="#1E1E1E">

    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <SolidColorBrush x:Key="CardBackground" Color="#2D2D30"/>
        <SolidColorBrush x:Key="TextPrimary" Color="White"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#AAAAAA"/>
        <SolidColorBrush x:Key="AccentColor" Color="#FF6200EE"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Боковая панель - Избранное -->
        <Border Grid.Column="0" 
        Background="{StaticResource CardBackground}" 
        CornerRadius="15" 
        Margin="0,0,20,0"
        Padding="15">
            <StackPanel>
                <TextBlock Text="⭐ Избранное"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{StaticResource TextPrimary}"
                   Margin="0,0,0,15"/>

                <ListBox ItemsSource="{Binding FavoriteCities}"
                 SelectedItem="{Binding SelectedCity}"
                 Background="Transparent"
                 BorderThickness="0"
                 Height="350">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#3A3A3D"
                            Margin="0,5"
                            Padding="10"
                            CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Cursor="Hand"
                                        MouseLeftButtonUp="City_Click">
                                        <TextBlock Text="⭐" Foreground="#FFBB0A1E" FontSize="14" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Name}" Foreground="White" FontSize="14"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                    Content="Х"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#FF6666"
                                    FontSize="13"
                                    Cursor="Hand"
                                    Width="25" Height="20"
                                    Click="RemoveFavorite_Click"
                                    Tag="{Binding Name}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="Поиск города"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="{StaticResource TextPrimary}"
                   Margin="0,20,0,10"/>

                <TextBox Text="{Binding SearchCity, UpdateSourceTrigger=PropertyChanged}"
                 Height="40"
                 FontSize="14"
                 Foreground="Black"
                 Background="White"
                 Padding="10"
                 Margin="0,0,0,10"/>

                <Button Content="Найти"
                Command="{Binding SearchCommand}"
                Background="{StaticResource AccentColor}"
                Foreground="White"
                FontSize="14"
                FontWeight="Bold"
                Cursor="Hand"
                BorderThickness="0"
                Height="35"
                Margin="0,0,0,10"/>

                <Button Content="Обновить"
                Command="{Binding RefreshCommand}"
                Background="#3A3A3D"
                Foreground="White"
                FontSize="14"
                Cursor="Hand"
                BorderThickness="0"
                Height="35"
                Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Основное содержимое -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="20,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Текущая погода -->
                <Border Grid.Row="0"
                        Background="{StaticResource CardBackground}"
                        CornerRadius="15"
                        Padding="20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding City}" 
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>

                            <Button Grid.Column="1" 
                                    Command="{Binding AddToFavoritesCommand}"
                                    Width="40" Height="40" FontSize="20"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Content" Value="☆"/>
                                        <Setter Property="Foreground" Value="#888"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                <Setter Property="Content" Value="⭐"/>
                                                <Setter Property="Foreground" Value="#FFBB0A1E"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <TextBlock Text="{Binding Description}"
                                   FontSize="16"
                                   Foreground="#88BBFF"
                                   Margin="0,5,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Margin="5,5,5,32" Padding="15" Background="#3A3A3D" CornerRadius="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Temperature, StringFormat={}{0:F1}°C}" FontSize="22" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Температура" FontSize="12" Foreground="#888" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Margin="5,5,5,32" Padding="15" Background="#3A3A3D" CornerRadius="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Humidity, StringFormat={}{0}%}" FontSize="22" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Влажность" FontSize="12" Foreground="#888" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Margin="5,5,5,32" Padding="15" Background="#3A3A3D" CornerRadius="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding WindSpeed, StringFormat={}{0:F1} м/с}" FontSize="22" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Ветер" FontSize="12" Foreground="#888" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="3" Margin="5,5,5,32" Padding="15" Background="#3A3A3D" CornerRadius="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Pressure, StringFormat={}{0} hPa}" FontSize="22" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Давление" FontSize="12" Foreground="#888" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock Text="{Binding LastUpdate, StringFormat='Последнее обновление: HH:mm:ss dd.MM.yyyy'}" 
                                   FontSize="11" 
                                   Foreground="#666" 
                                   HorizontalAlignment="Right" 
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- График температуры -->
                <Border Grid.Row="1"
                        Background="{StaticResource CardBackground}"
                        CornerRadius="15"
                        Padding="20"
                        Margin="0,0,0,20"
                        Height="450">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="График температуры (по часам)"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,20"/>

                        <lvc:CartesianChart Grid.Row="1"
                                            Series="{Binding Series}"
                                            XAxes="{Binding XAxes}"
                                            Background="#1A1A1A"/>
                    </Grid>
                </Border>

                <!-- Прогноз на 5 дней -->
                <Border Grid.Row="2"
                        Background="{StaticResource CardBackground}"
                        CornerRadius="15"
                        Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Прогноз на 5 дней"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,15"/>

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding DailyForecasts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#3A3A3D" 
                                            CornerRadius="10" 
                                            Width="200" 
                                            Margin="10" 
                                            Padding="15">
                                        <StackPanel>
                                            <TextBlock FontWeight="Bold" Foreground="White" FontSize="14" HorizontalAlignment="Center">
                                                <Run Text="{Binding Date, StringFormat=dd.MM}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding Date, StringFormat=dddd}"/>
                                            </TextBlock>

                                            <TextBlock Text="{Binding Description}" 
                                                       Foreground="#88BBFF" 
                                                       FontSize="12" 
                                                       TextWrapping="Wrap"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,10,0,10"/>

                                            <Grid Margin="0,5,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" Background="#2A2A2D" CornerRadius="8" Padding="10" Margin="0,0,5,0">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text=" Мин" FontSize="10" Foreground="#888"/>
                                                        <TextBlock Foreground="#88BBFF" FontSize="18" HorizontalAlignment="Center">
                                                            <Run Text="{Binding MinTemp, StringFormat={}{0:F1}}"/>
                                                            <Run Text="°C"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="1" Background="#2A2A2D" CornerRadius="8" Padding="10" Margin="5,0,0,0">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text=" Макс" FontSize="10" Foreground="#888"/>
                                                        <TextBlock Foreground="#FF8888" FontSize="18" HorizontalAlignment="Center">
                                                            <Run Text="{Binding MaxTemp, StringFormat={}{0:F1}}"/>
                                                            <Run Text="°C"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
    